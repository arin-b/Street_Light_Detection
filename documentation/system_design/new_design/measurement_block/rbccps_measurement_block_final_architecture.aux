\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Latent emission-state inference. Temporal lamp crops, exposure tokens, saturation tokens, and occlusion tokens feed state heads for emission, occlusion, capture corruption, flicker, confidence, and status.}}{11}{figure.4}\protected@file@percent }
\newlabel{fig:module-lamp-status}{{4}{11}{Latent emission-state inference. Temporal lamp crops, exposure tokens, saturation tokens, and occlusion tokens feed state heads for emission, occlusion, capture corruption, flicker, confidence, and status}{figure.4}{}}
