\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Metadata-conditioned radiometric normalization. The module produces an exposure-aware luma proxy and reliability products while explicitly marking saturation, bloom, exposure jumps, and insufficient physical validity.}}{10}{figure.3}\protected@file@percent }
